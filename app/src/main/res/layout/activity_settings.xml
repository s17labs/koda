<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kodaEditorBg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/ic_back"
                app:tint="@color/kodaText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textColor="@color/kodaText"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingStart="8dp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_main"
            android:textColor="@color/kodaBlue"
            android:textSize="14sp"
            android:textStyle="bold"
			android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/settingOpenNew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_open_new"
                    android:textColor="@color/kodaText"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/textOpenNewDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_open_new_desc"
                    android:textColor="@color/kodaTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.s17labs.koda.CustomToggleView
                android:id="@+id/switchOpenNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingOpenLast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_open_last"
                    android:textColor="@color/kodaText"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/textOpenLastDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_open_last_desc"
                    android:textColor="@color/kodaTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.s17labs.koda.CustomToggleView
                android:id="@+id/switchOpenLast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingAutoSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_auto_save"
                    android:textColor="@color/kodaText"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_auto_save_desc"
                    android:textColor="@color/kodaTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.s17labs.koda.CustomToggleView
                android:id="@+id/switchAutoSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingWrapLines"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_wrap_lines"
                    android:textColor="@color/kodaText"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_wrap_lines_desc"
                    android:textColor="@color/kodaTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.s17labs.koda.CustomToggleView
                android:id="@+id/switchWrapLines"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingWakeLock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_wake_lock"
                    android:textColor="@color/kodaText"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_wake_lock_desc"
                    android:textColor="@color/kodaTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.s17labs.koda.CustomToggleView
                android:id="@+id/switchWakeLock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_appearance"
            android:textColor="@color/kodaBlue"
            android:textSize="14sp"
            android:textStyle="bold"
			android:paddingHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/settingLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setting_language"
                android:textColor="@color/kodaText"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textLanguageValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="English"
                android:textColor="@color/kodaTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingFont"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setting_font"
                android:textColor="@color/kodaText"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textFontValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monospace"
                android:textColor="@color/kodaTextSecondary"
                android:textSize="12sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setting_font_size"
                android:textColor="@color/kodaText"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textFontSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M"
                android:textColor="@color/kodaTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_about"
            android:textColor="@color/kodaBlue"
            android:textSize="14sp"
            android:textStyle="bold"
			android:paddingHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/version"
                android:textColor="@color/kodaText"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textColor="@color/kodaTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
			android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_koda"
                android:textColor="@color/kodaText"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_koda_desc"
                android:textColor="@color/kodaTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingDebugLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_log"
                android:textColor="@color/kodaText"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_log_desc"
                android:textColor="@color/kodaTextSecondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
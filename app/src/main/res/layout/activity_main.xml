<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/kodaEditorBg"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/kodaDarkBlue"
        android:paddingHorizontal="8dp">

        <ImageView
            android:id="@+id/toolbarIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_launcher"
            android:paddingStart="4dp"
            android:contentDescription="Koda" />

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/toolbarIcon"
            android:layout_centerVertical="true"
            android:text="Koda"
            android:textColor="@color/kodaText"
            android:textSize="32sp"
            android:textStyle="bold"
			android:typeface="monospace"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:src="@drawable/ic_menu"
                app:tint="@color/kodaText" />

        </LinearLayout>

    </RelativeLayout>

    <HorizontalScrollView
        android:id="@+id/tabScrollView"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/kodaTabInactive"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/tabContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fitsSystemWindows="true">

        <include
            android:id="@+id/startPage"
            layout="@layout/view_start_page"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/editorContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="vertical"
                android:scrollbarStyle="insideInset">

                <EditText
                    android:id="@+id/textEditor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/kodaEditorBg"
                    android:gravity="top|start"
                    android:hint="@string/start_typing"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:padding="16dp"
                    android:textColor="@color/kodaText"
                    android:textColorHint="@color/kodaTextSecondary"
                    android:textSize="14sp"
                    android:typeface="monospace"
                    android:scrollbars="vertical" />

            </ScrollView>

        </LinearLayout>

        <TextView
            android:id="@+id/textEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/empty_state_message"
            android:textColor="@color/kodaTabInactive"
            android:textSize="16sp"
            android:visibility="gone"
            android:padding="32dp" 
			android:typeface="monospace" />

    </FrameLayout>

</LinearLayout>
